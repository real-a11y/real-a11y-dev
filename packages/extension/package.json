{
  "name": "@real-a11y-dev/semantic-navigator-extension",
  "version": "0.1.7",
  "private": true,
  "description": "Semantic Navigator — Chrome extension for the Real A11y project. Inspect and interact with the accessibility tree of any page.",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/sync-manifest-version.mjs",
    "build": "vite build && cross-env BUILD_TARGET=content vite build",
    "dev": "vite build --watch",
    "package": "pnpm build && node scripts/zip-for-cws.mjs",
    "typecheck": "node scripts/sync-manifest-version.mjs --check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:spike": "vitest run --config spike/vitest.config.ts"
  },
  "dependencies": {
    "@real-a11y-dev/core": "workspace:*",
    "@real-a11y-dev/semantic-navigator-ui": "workspace:*",
    "@real-a11y-dev/serialize": "workspace:*",
    "preact": "^10.29.7"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.6",
    "@types/chrome": "^0.2.2",
    "@vitest/coverage-v8": "^3.2.7",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.49.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
