{
  "name": "@real-a11y-dev/example-patterns",
  "private": true,
  "version": "0.0.0",
  "description": "APG-coverage component library shared across the example apps. Re-exports correct implementations from @radix-ui/* and ships hand-rolled `*Broken` siblings to demo what Real A11y catches.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-toast": "^1.2.20",
    "@radix-ui/react-toolbar": "^1.1.16",
    "react-aria-components": "^1.19.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
