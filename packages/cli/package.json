{
  "name": "@real-a11y-dev/cli",
  "version": "0.1.0-beta.1",
  "description": "Audit what a screen reader hears, from your shell — semantic-tree accessibility audits with CI-grade exit codes and formats",
  "license": "MIT",
  "author": "Juan Crisostomo (Real A11y)",
  "repository": {
    "type": "git",
    "url": "https://github.com/real-a11y/real-a11y-dev.git",
    "directory": "packages/cli"
  },
  "homepage": "https://real-a11y.dev",
  "bugs": {
    "url": "https://github.com/real-a11y/real-a11y-dev/issues"
  },
  "keywords": [
    "a11y",
    "accessibility",
    "aria",
    "cli",
    "audit",
    "ci",
    "semantic-tree",
    "screen-reader"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "real-a11y": "./dist/index.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@real-a11y-dev/audit": "workspace:*",
    "@real-a11y-dev/browser": "workspace:*",
    "@real-a11y-dev/snapshot": "workspace:*"
  },
  "peerDependencies": {
    "playwright": ">=1.49.0 <2"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.61.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.7"
  }
}
