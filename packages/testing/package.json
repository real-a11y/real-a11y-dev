{
  "name": "@real-a11y-dev/testing",
  "version": "0.1.0-beta.4",
  "description": "Accessibility audit and interaction-flow helpers for the Semantic Navigator tree (Vitest, Jest, Playwright)",
  "license": "MIT",
  "author": "Juan Crisostomo (Real A11y)",
  "repository": {
    "type": "git",
    "url": "https://github.com/real-a11y/real-a11y-dev.git",
    "directory": "packages/testing"
  },
  "homepage": "https://real-a11y.dev/packages/testing",
  "bugs": {
    "url": "https://github.com/real-a11y/real-a11y-dev/issues"
  },
  "keywords": [
    "a11y",
    "accessibility",
    "aria",
    "testing",
    "vitest",
    "jest",
    "playwright",
    "audit",
    "snapshot"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./playwright": {
      "import": {
        "types": "./dist/playwright.d.ts",
        "default": "./dist/playwright.js"
      },
      "require": {
        "types": "./dist/playwright.d.cts",
        "default": "./dist/playwright.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "snapshot": "node scripts/snapshot.mjs"
  },
  "dependencies": {
    "@real-a11y-dev/core": "workspace:*"
  },
  "peerDependencies": {
    "playwright": "*"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
