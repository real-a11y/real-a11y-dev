{
  "name": "@real-a11y-dev/mcp",
  "version": "0.1.0-beta.0",
  "description": "Model Context Protocol server that exposes the Real A11y semantic tree and accessibility audits to AI agents",
  "license": "MIT",
  "author": "Juan Crisostomo (Real A11y)",
  "repository": {
    "type": "git",
    "url": "https://github.com/real-a11y/real-a11y-dev.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://real-a11y.dev",
  "bugs": {
    "url": "https://github.com/real-a11y/real-a11y-dev/issues"
  },
  "keywords": [
    "a11y",
    "accessibility",
    "aria",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "audit"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "real-a11y-mcp": "./dist/index.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@real-a11y-dev/audit": "workspace:*",
    "@real-a11y-dev/browser": "workspace:*",
    "@real-a11y-dev/snapshot": "workspace:*",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "playwright": ">=1.49.0 <2"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.61.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.7"
  }
}
