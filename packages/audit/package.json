{
  "name": "@real-a11y-dev/audit",
  "version": "0.1.0-beta.11",
  "description": "The accessibility audit engine for the Semantic Navigator tree — the Finding type, the rule set, collectFindings, and the throwing assert* helpers. What every Real A11y surface reports as \"broken\", in one place.",
  "license": "MIT",
  "author": "Juan Crisostomo (Real A11y)",
  "repository": {
    "type": "git",
    "url": "https://github.com/real-a11y/real-a11y-dev.git",
    "directory": "packages/audit"
  },
  "homepage": "https://real-a11y.dev",
  "bugs": {
    "url": "https://github.com/real-a11y/real-a11y-dev/issues"
  },
  "keywords": [
    "a11y",
    "accessibility",
    "aria",
    "accessibility-tree",
    "audit",
    "findings",
    "screen-reader"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@real-a11y-dev/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.7"
  }
}
