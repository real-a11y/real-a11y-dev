# Run the full verify gate (build + typecheck + tests) before allowing a push.
# Catches CI failures locally so the pipeline doesn't fail on review-time
# issues (missing types, JSX config, broken tests).
#
# Skip in emergencies with `git push --no-verify`.
pnpm verify

# Bundle-size budget gate (mirrors CI). `verify` already built the public
# packages, so size-limit reads fresh dist/ output — no rebuild needed.
# Budgets live in .size-limit.json.
pnpm size-limit
