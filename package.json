{
  "name": "real-a11y",
  "private": true,
  "description": "Real A11y monorepo — accessibility tooling that works in the real world. Semantic tree extraction, testing utilities, React integration, Storybook panel, and Chrome extension.",
  "scripts": {
    "build": "pnpm -r --filter \"!@real-a11y-dev/website\" --filter \"!@real-a11y-dev/example-vanilla\" --filter \"!@real-a11y-dev/example-react\" --filter \"!@real-a11y-dev/example-storybook\" --filter \"!@real-a11y-dev/example-testing\" build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r --filter \"!@real-a11y-dev/website\" --filter \"!@real-a11y-dev/example-vanilla\" --filter \"!@real-a11y-dev/example-react\" --filter \"!@real-a11y-dev/example-storybook\" --filter \"!@real-a11y-dev/example-testing\" test",
    "lint": "eslint packages/ website/scripts website/tests",
    "lint:fix": "eslint packages/ website/scripts website/tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --filter \"!@real-a11y-dev/website\" --filter \"!@real-a11y-dev/example-vanilla\" --filter \"!@real-a11y-dev/example-react\" --filter \"!@real-a11y-dev/example-storybook\" --filter \"!@real-a11y-dev/example-testing\" typecheck",
    "verify": "pnpm build && pnpm typecheck && pnpm format:check && pnpm lint && pnpm test && pnpm --filter @real-a11y-dev/website build",
    "a11y:snapshot": "pnpm --filter @real-a11y-dev/testing snapshot",
    "rasterize-icons": "pnpm --filter @real-a11y-dev/testing exec node scripts/rasterize-extension-icons.mjs",
    "rasterize-og": "pnpm --filter @real-a11y-dev/testing exec node scripts/rasterize-og-image.mjs",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "size": "pnpm build && size-limit",
    "size:why": "pnpm build && size-limit --why",
    "commitlint": "commitlint",
    "packaging:check": "node scripts/check-packaging.mjs",
    "examples:dev-smoke": "node scripts/check-examples-dev.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.27.10",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/chrome": "^0.1.42",
    "@vitest/browser": "^4.1.7",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "uuid@<14.0.0": ">=14.0.0",
      "vite@<6.4.2": ">=6.4.2",
      "esbuild@<0.25.0": ">=0.25.0",
      "glob@10.2.0 - 10.4.x": ">=10.5.0"
    }
  }
}
